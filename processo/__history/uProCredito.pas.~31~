implementation

{$R *.dfm}

procedure TfrmProCredito.FormCreate(Sender: TObject);
begin
 IndiceAtual :='nome';
end;

procedure TfrmProCredito.FormShow(Sender: TObject);
begin
  inherited;
  CentralizarDadosGrid(grdListagem);
  CentralizarTitulosGrid(grdListagem);
  CarregarColunas(grdListagem);
end;





procedure TfrmProCredito.grdListagemDblClick(Sender: TObject);
var
  MsgCredito: string;
   MsgVenda: string;
begin

  if UpperCase(FDQListagem.FieldByName('tipo').AsString) = 'ENTRADA' then
    MsgCredito := 'teve  adicionado ‡ sua conta o valor de R$ '
  else
    MsgCredito := 'teve removido da sua conta o valor de R$ ';

    if FDQListagem.FieldByName('vendaId').IsNull then
    MsgVenda := '.'
  else
    MsgVenda := ' referente ‡ venda N∫ ' +
      FDQListagem.FieldByName('vendaId').AsString ;

  ShowMessage(

    'O cliente ' +
    FDQListagem.FieldByName('nome').AsString + ' ' +

    MsgCredito +

    FormatFloat('#,##0.00',
      FDQListagem.FieldByName('credito').AsFloat) +

    ' em ' +

    FormatDateTime(
      'dd/mm/yyyy ',
      FDQListagem.FieldByName('data').AsDateTime
    ) + MsgVenda+ '.'

  );

end;

end.

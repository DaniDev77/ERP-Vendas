unit uSelecionarData;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, Vcl.Buttons, Vcl.Mask, RxToolEdit,System.DateUtils;

type
  TfrmSelecionarData = class(TForm)
    Label1: TLabel;
    Label2: TLabel;
    edtDataFinal: TDateEdit;
    BitBtn1: TBitBtn;
    edtDataInicio: TDateEdit;
    procedure BitBtn1Click(Sender: TObject);
    procedure FormShow(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  frmSelecionarData: TfrmSelecionarData;

implementation

{$R *.dfm}



procedure TfrmSelecionarData.BitBtn1Click(Sender: TObject);
begin
  try
    OutputDebugString('>> BitBtn1Click iniciou');

    OutputDebugString('>> Verificando edtDataInicio...');
    if not Assigned(edtDataInicio) then
    begin
      OutputDebugString('>> edtDataInicio Ú NIL!');
      Exit;
    end;
    OutputDebugString(PChar('>> edtDataInicio.Text = ' + edtDataInicio.Text));

    OutputDebugString('>> Verificando edtDataFinal...');
    if not Assigned(edtDataFinal) then
    begin
      OutputDebugString('>> edtDataFinal Ú NIL!');
      Exit;
    end;
    OutputDebugString(PChar('>> edtDataFinal.Text = ' + edtDataFinal.Text));

    if Trim(edtDataInicio.Text) = '' then
    begin
      OutputDebugString('>> DataInicio vazio');
      MessageDlg('Data Inicial Ú campo obrigatˇrio.', mtWarning, [mbOK], 0);
      Exit;
    end;

    if Trim(edtDataFinal.Text) = '' then
    begin
      OutputDebugString('>> DataFinal vazio');
      MessageDlg('Data Final Ú campo obrigatˇrio.', mtWarning, [mbOK], 0);
      Exit;
    end;

    OutputDebugString('>> Comparando datas...');
    OutputDebugString(PChar('>> Inicio: ' + DateToStr(edtDataInicio.Date)));
    OutputDebugString(PChar('>> Fim:    ' + DateToStr(edtDataFinal.Date)));

    if edtDataFinal.Date < edtDataInicio.Date then
    begin
      OutputDebugString('>> Data Final menor que Inicial');
      MessageDlg('Data Final nŃo pode ser menor que a Data Inicial.', mtWarning, [mbOK], 0);
      Exit;
    end;

    OutputDebugString('>> Tudo OK, setando mrOk');
    ModalResult := mrOk;

  except
    on E: Exception do
    begin
      OutputDebugString(PChar('>> EXCEPTION: ' + E.ClassName + ' - ' + E.Message));
      raise;
    end;
  end;
end;

procedure TfrmSelecionarData.FormShow(Sender: TObject);
begin
 edtDataInicio.Date := StartOftheMonth(Date);
 edtDataFinal.Date  := EndOfTheMonth(Date);
end;

end.
